{
  "title": "Jiraflow — Backend Logs",
  "uid": "jiraflow-backend-logs",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },
  "timepicker": {},
  "tags": ["jiraflow", "logs", "backend"],
  "templating": {
    "list": [
      {
        "name": "level",
        "label": "Level",
        "type": "custom",
        "query": "error,warn,info,debug",
        "current": { "text": "All", "value": "$__all" },
        "includeAll": true,
        "allValue": ".*",
        "multi": false,
        "options": [
          { "text": "All",   "value": "$__all", "selected": true },
          { "text": "error", "value": "error" },
          { "text": "warn",  "value": "warn" },
          { "text": "info",  "value": "info" },
          { "text": "debug", "value": "debug" }
        ]
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Errors (1h)",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 3 },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value", "reduceOptions": { "calcs": ["sum"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 1 },
            { "color": "red", "value": 10 }
          ]}
        }
      },
      "targets": [{
        "datasource": { "type": "loki", "uid": "grafanacloud-charmingcushion1934-logs" },
        "expr": "sum(count_over_time({app=\"jiraflow-backend\"} | json | level=\"error\" [1h]))",
        "instant": true,
        "refId": "A"
      }]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Warnings (1h)",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 3 },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value", "reduceOptions": { "calcs": ["sum"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 5 },
            { "color": "orange", "value": 50 }
          ]}
        }
      },
      "targets": [{
        "datasource": { "type": "loki", "uid": "grafanacloud-charmingcushion1934-logs" },
        "expr": "sum(count_over_time({app=\"jiraflow-backend\"} | json | level=\"warn\" [1h]))",
        "instant": true,
        "refId": "A"
      }]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Total Logs (1h)",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 3 },
      "options": { "colorMode": "value", "graphMode": "area", "textMode": "value", "reduceOptions": { "calcs": ["sum"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "blue" }
        }
      },
      "targets": [{
        "datasource": { "type": "loki", "uid": "grafanacloud-charmingcushion1934-logs" },
        "expr": "sum(count_over_time({app=\"jiraflow-backend\"} [1h]))",
        "instant": true,
        "refId": "A"
      }]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Last Log",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 3 },
      "options": { "colorMode": "value", "graphMode": "none", "textMode": "value", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "dateTimeFromNow",
          "color": { "mode": "fixed", "fixedColor": "text" }
        }
      },
      "targets": [{
        "datasource": { "type": "loki", "uid": "grafanacloud-charmingcushion1934-logs" },
        "expr": "sum(count_over_time({app=\"jiraflow-backend\"} [5m]))",
        "instant": true,
        "refId": "A"
      }]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Log Rate",
      "gridPos": { "x": 0, "y": 3, "w": 24, "h": 7 },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "logs/s",
          "custom": { "lineWidth": 2, "fillOpacity": 15, "gradientMode": "opacity" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "error" }, "properties": [{ "id": "color", "value": { "fixedColor": "#F2495C", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "warn"  }, "properties": [{ "id": "color", "value": { "fixedColor": "#FF9830", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "info"  }, "properties": [{ "id": "color", "value": { "fixedColor": "#5794F2", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "debug" }, "properties": [{ "id": "color", "value": { "fixedColor": "#73BF69", "mode": "fixed" } }] }
        ]
      },
      "targets": [{
        "datasource": { "type": "loki", "uid": "grafanacloud-charmingcushion1934-logs" },
        "expr": "sum by (level) (rate({app=\"jiraflow-backend\"} | json [$__interval]))",
        "legendFormat": "{{level}}",
        "refId": "A"
      }]
    },
    {
      "id": 6,
      "type": "logs",
      "title": "Logs",
      "gridPos": { "x": 0, "y": 10, "w": 24, "h": 20 },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": false,
        "sortOrder": "Descending"
      },
      "targets": [{
        "datasource": { "type": "loki", "uid": "grafanacloud-charmingcushion1934-logs" },
        "expr": "{app=\"jiraflow-backend\"} | json | level=~\"$level\"",
        "legendFormat": "",
        "refId": "A"
      }]
    }
  ]
}
