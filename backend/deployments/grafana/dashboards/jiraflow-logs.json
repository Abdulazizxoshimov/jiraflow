{
  "title": "Jiraflow — Application Logs",
  "uid": "jiraflow-logs",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "templating": {
    "list": [
      {
        "name": "environment",
        "label": "Environment",
        "type": "custom",
        "query": "development,production",
        "current": { "text": "development", "value": "development" },
        "options": [
          { "text": "development", "value": "development" },
          { "text": "production", "value": "production" }
        ],
        "includeAll": true,
        "allValue": ".*"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Errors (last 1h)",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({app=\"jiraflow-backend\", environment=~\"$environment\"} | json | level=\"error\" [1h]))",
          "instant": true,
          "legendFormat": "Errors"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Warnings (last 1h)",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "orange", "value": 50 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({app=\"jiraflow-backend\", environment=~\"$environment\"} | json | level=\"warn\" [1h]))",
          "instant": true,
          "legendFormat": "Warnings"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Log Volume (last 1h)",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({app=\"jiraflow-backend\", environment=~\"$environment\"} [1h]))",
          "instant": true,
          "legendFormat": "Total"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Log Rate by Level",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 8 },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "reqps"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "error" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "warn" },
            "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "info" },
            "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }]
          }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum by (level) (rate({app=\"jiraflow-backend\", environment=~\"$environment\"} | json [1m]))",
          "legendFormat": "{{level}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "logs",
      "title": "Error Logs",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 12 },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showTime": true,
        "wrapLogMessage": false,
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{app=\"jiraflow-backend\", environment=~\"$environment\"} | json | level=~\"error|warn\"",
          "legendFormat": ""
        }
      ]
    },
    {
      "id": 6,
      "type": "logs",
      "title": "All Logs",
      "gridPos": { "x": 0, "y": 24, "w": 24, "h": 14 },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showTime": true,
        "wrapLogMessage": false,
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{app=\"jiraflow-backend\", environment=~\"$environment\"} | json",
          "legendFormat": ""
        }
      ]
    }
  ]
}
