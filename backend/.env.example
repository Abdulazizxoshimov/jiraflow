# ─── App ──────────────────────────────────────────────────────────────────────
APP_PORT=8080
APP_ENV=development
LOG_LEVEL=info
FRONTEND_BASE_URL=http://localhost:3000

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=jiraflow
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_MAX_CONNS=50
DB_MIN_CONNS=5
DB_MAX_CONN_IDLE_TIME=5m
DB_MAX_CONN_LIFETIME=30m
DB_HEALTH_CHECK_PERIOD=1m
# Yoki to'liq URL (yuqoridagi sozlamalarni override qiladi):
# DATABASE_URL=postgres://postgres:password@localhost:5432/jiraflow?sslmode=disable

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ─── MinIO ────────────────────────────────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=jiraflow
MINIO_USE_SSL=false

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Kamida 32 belgili tasodifiy string: openssl rand -hex 32
JWT_SECRET=change_me_to_a_strong_random_secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

# ─── SMTP (Email) ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_FROM=noreply@example.com
SMTP_USERNAME=your_gmail@gmail.com
SMTP_PASSWORD=your_app_password

# ─── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/api/v1/auth/google/callback

# ─── Sentry ───────────────────────────────────────────────────────────────────
# DSN: Sentry project settings → Client Keys
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.2

# ─── Grafana Loki ─────────────────────────────────────────────────────────────
# Leave empty to disable log shipping (stdout logging is always active)
LOKI_URL=http://localhost:3100

# ─── Grafana ──────────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=admin
