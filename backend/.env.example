# ─── App ──────────────────────────────────────────────────────────────────────
APP_PORT=8080
APP_ENV=development
LOG_LEVEL=info
FRONTEND_BASE_URL=http://localhost:3000

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=jiraflow
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_MAX_CONNS=50
DB_MIN_CONNS=5
DB_MAX_CONN_IDLE_TIME=5m
DB_MAX_CONN_LIFETIME=30m
DB_HEALTH_CHECK_PERIOD=1m
# Yoki to'liq URL (yuqoridagi sozlamalarni override qiladi):
# DATABASE_URL=postgres://postgres:password@localhost:5432/jiraflow?sslmode=disable

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ─── MinIO ────────────────────────────────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=jiraflow
MINIO_USE_SSL=false

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Kamida 32 belgili tasodifiy string: openssl rand -hex 32
JWT_SECRET=change_me_to_a_strong_random_secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

# ─── SMTP (Email) ─────────────────────────────────────────────────────────────
# Set EMAIL_ENABLED=false to disable all email sending (e.g. in local/test envs)
EMAIL_ENABLED=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_FROM=noreply@example.com
SMTP_USERNAME=your_gmail@gmail.com
SMTP_PASSWORD=your_app_password

# ─── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/api/v1/auth/google/callback

# ─── Sentry ───────────────────────────────────────────────────────────────────
# DSN: Sentry project settings → Client Keys
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.2

# ─── Rate limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_RPS=30
RATE_LIMIT_BURST=60

# ─── Registration ─────────────────────────────────────────────────────────────
# true  → anyone can register (public SaaS mode)
# false → only admin can invite users (default, recommended for production)
ALLOW_OPEN_REGISTRATION=false

# ─── RabbitMQ (async email queue) ─────────────────────────────────────────────
# Docker Compose: amqp://guest:guest@rabbitmq:5672/
# Local dev:      amqp://guest:guest@localhost:5672/
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# ─── Nginx / Domain ───────────────────────────────────────────────────────────
# Used by nginx container to set server_name and SSL cert paths
DOMAIN=yourdomain.com

# ─── Grafana Loki ─────────────────────────────────────────────────────────────
# Self-hosted (local docker-compose):
# LOKI_URL=http://localhost:3100
# LOKI_USER=
# LOKI_PASSWORD=
#
# Grafana Cloud:
LOKI_URL=https://logs-prod-ap-southeast1.grafana.net
LOKI_USER=1802942
LOKI_PASSWORD=your-grafana-cloud-token

# ─── Grafana ──────────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=admin

# ─── Telegram Bot ─────────────────────────────────────────────────────────────
# Get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=your_bot_username
# Public URL that receives webhook updates from Telegram
# Must be HTTPS. Example: https://api.yourdomain.com/telegram/webhook
TELEGRAM_WEBHOOK_URL=
# Random secret to verify webhook requests from Telegram (min 1-256 chars)
TELEGRAM_WEBHOOK_SECRET=change_to_random_secret
